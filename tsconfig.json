{
	"extends": "astro/tsconfigs/strictest",
	"compilerOptions": {
		"baseUrl": ".",
		"paths": {
			"@/*": [
				"src/*"
			],
			"@components/*": [
				"src/components/*"
			],
			"@layouts/*": [
				"src/layouts/*"
			],
			"@lib/*": [
				"src/lib/*"
			],
			"@styles/*": [
				"src/styles/*"
			],
			"@config/*": [
				"src/config/*"
			]
		}
	},
	"include": [
		".astro/types.d.ts",
		"src/**/*",
		"./worker-configuration.d.ts"
	],
	"exclude": [
		"dist",
		"node_modules"
	]
}