---
import BaseLayout from "@layouts/BaseLayout.astro";
import Header from "@components/shell/Header.astro";
import Footer from "@components/shell/Footer.astro";
---

<BaseLayout title="Cheat-Sheet" description="Die wichtigsten Befehle auf einen Blick: Start, Stop, Logs, GPU und Downloads.">
  <Header />

  <main class="page">
    <div class="hero">
      <p class="badge">Kurzreferenz</p>
      <h1>Cheat-Sheet</h1>
      <p class="lead">Die wichtigsten Befehle fur den taglichen Workflow &mdash; auf einen Blick.</p>
    </div>

    <div class="grid">

      <section class="sheet-card" aria-labelledby="heading-start">
        <h2 id="heading-start">Start</h2>
        <pre><code>ssh m4z-d1t@hal9000.skim.th-owl.de
cd /data/pool/m4z-d1t/comfyui-project
sudo docker start comfyui_data
sudo docker ps</code></pre>
      </section>

      <section class="sheet-card" aria-labelledby="heading-browser">
        <h2 id="heading-browser">Browser</h2>
        <pre><code>http://hal9000.skim.th-owl.de:8188</code></pre>
      </section>

      <section class="sheet-card" aria-labelledby="heading-stop">
        <h2 id="heading-stop">Stop</h2>
        <pre><code>sudo docker stop comfyui_data</code></pre>
      </section>

      <section class="sheet-card" aria-labelledby="heading-logs">
        <h2 id="heading-logs">Logs</h2>
        <pre><code>sudo docker logs --tail 100 comfyui_data</code></pre>
      </section>

      <section class="sheet-card" aria-labelledby="heading-live-logs">
        <h2 id="heading-live-logs">Live-Logs</h2>
        <pre><code>sudo docker logs -f comfyui_data</code></pre>
      </section>

      <section class="sheet-card" aria-labelledby="heading-gpu-check">
        <h2 id="heading-gpu-check">GPU prufen</h2>
        <pre><code>nvidia-smi</code></pre>
      </section>

      <section class="sheet-card" aria-labelledby="heading-gpu-live">
        <h2 id="heading-gpu-live">GPU live</h2>
        <pre><code>watch -n 1 nvidia-smi</code></pre>
      </section>

      <section class="sheet-card sheet-card--wide" aria-labelledby="heading-gpu-wechsel">
        <h2 id="heading-gpu-wechsel">Container mit anderer GPU neu erstellen</h2>
        <pre><code>sudo docker stop comfyui_data
sudo docker rm comfyui_data
sudo docker run -d \
  --name comfyui_data \
  --gpus '"device=5"' \
  -p 8188:8188 \
  -v /data/pool/m4z-d1t/comfyui-project/models:/app/models \
  -v /data/pool/m4z-d1t/comfyui-project/output:/app/output \
  -v /data/pool/m4z-d1t/comfyui-project/custom_nodes:/app/custom_nodes \
  -v /data/pool/m4z-d1t/comfyui-project/workflows:/app/user \
  comfyui-custom-torch271</code></pre>
      </section>

      <section class="sheet-card sheet-card--wide" aria-labelledby="heading-download">
        <h2 id="heading-download">Modell herunterladen</h2>
        <pre><code>mkdir -p /data/pool/m4z-d1t/comfyui-project/models/ORDNER
wget -c --show-progress -O /data/pool/m4z-d1t/comfyui-project/models/ORDNER/datei.safetensors "DIREKTER_LINK"</code></pre>
      </section>

    </div>

    <div class="cta">
      <p>Detaillierte Erklarungen zu jedem Befehl findest du in der <a href="/befehlslegende/">Befehlslegende</a>.</p>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .page {
    max-width: 960px;
    margin: 0 auto;
    padding: var(--space-8) var(--space-6) var(--space-24);
  }

  .hero {
    margin-block-end: var(--space-16);
    text-align: center;
  }

  .badge {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    background-color: transparent;
    border: 1px solid var(--color-accent);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    margin-block-end: var(--space-4);
  }

  h1 {
    font-size: var(--text-4xl);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin-block-end: var(--space-4);
  }

  .lead {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    max-width: 48ch;
    margin: 0 auto;
    line-height: var(--leading-relaxed);
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .sheet-card {
    padding: var(--space-5);
    background-color: var(--color-surface-1);
    border: 1px solid var(--color-surface-3);
    border-radius: var(--radius-lg);
  }

  .sheet-card--wide {
    grid-column: 1 / -1;
  }

  .sheet-card h2 {
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
    margin-block-end: var(--space-3);
    padding-block-end: var(--space-2);
    border-bottom: 1px solid var(--color-surface-3);
  }

  .sheet-card pre {
    font-size: var(--text-xs);
    background-color: var(--color-surface-2);
    padding: var(--space-3);
    border-radius: var(--radius-md);
    overflow-x: auto;
  }

  .sheet-card pre code {
    color: var(--color-text-primary);
    font-family: var(--font-mono);
    line-height: var(--leading-relaxed);
  }

  .cta {
    text-align: center;
    margin-block-start: var(--space-16);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .cta a {
    color: var(--color-accent);
    font-weight: var(--font-weight-medium);
    text-underline-offset: 2px;
  }

  .cta a:hover {
    text-decoration: none;
  }
</style>
