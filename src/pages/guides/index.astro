---
import { getCollection } from "astro:content";
import LandingLayout from "@layouts/LandingLayout.astro";
import GuideCard from "@components/content/GuideCard.astro";
import GuideGrid from "@components/content/GuideGrid.astro";
import type { GuideInfo } from "@components/content/GuideCard.astro";

const guides = await getCollection("guides", ({ data }) => !data.draft);

const beginnerGuide = guides.find((g) => g.id === "allgemein/erste-schritte-beginner.md");
const otherGuides = guides.filter((g) => g.id !== "allgemein/erste-schritte-beginner.md");

function toGuideInfo(g: (typeof guides)[number]): GuideInfo {
  return {
    title: g.data.title,
    description: g.data.description,
    difficulty: g.data.difficulty,
    topic: g.data.topic,
    readingTime: g.data.readingTimeMinutes ?? 5,
    href: `/guides/${g.id.replace(/\.md$/, "")}`,
  };
}

const sorted: GuideInfo[] = [
  ...(beginnerGuide ? [toGuideInfo(beginnerGuide)] : []),
  ...otherGuides
    .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
    .map(toGuideInfo),
];

---

<LandingLayout
  title="Anleitungen"
  description="Alle technischen Anleitungen – von SSH uber Docker und ComfyUI bis zu GPU-Konfiguration."
>
  <section class="overview">
    <div class="overview-inner">
      <h1 class="overview-heading">Anleitungen</h1>
      <p class="overview-lead">
        Schritt-fur-Schritt-Anleitungen fur den gesamten KI-Infrastruktur-Stack.
        Von den ersten SSH-Befehlen bis zur Multi-GPU-Konfiguration.
      </p>

      <GuideGrid>
        {sorted.map((guide) => <GuideCard {...guide} />)}
      </GuideGrid>
    </div>
  </section>
</LandingLayout>

<style>
  .overview {
    padding-block: var(--space-12) var(--space-20);
  }
  .overview-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 var(--space-6);
  }
  .overview-heading {
    font-size: var(--text-4xl);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin-block-end: var(--space-4);
  }
  .overview-lead {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    max-width: 56ch;
    margin-block-end: var(--space-12);
    line-height: var(--leading-relaxed);
  }
</style>
