---
import { getCollection } from "astro:content";
import LandingLayout from "@layouts/LandingLayout.astro";

const models = await getCollection("modelle", ({ data }) => !data.draft);
const sorted = models.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
---

<LandingLayout
  title="KI-Modelle"
  description="Ubersicht aller KI-Modelle – Checkpoints, LoRAs, VAEs und Text-Encoder mit VRAM-Anforderungen und Download-Quellen."
>
  <section class="overview">
    <div class="overview-inner">
      <h1 class="overview-heading">KI-Modelle</h1>
      <p class="overview-lead">
        Alle getesteten Modelle mit Download-Quellen, VRAM-Anforderungen und Verwendungszweck.
      </p>
      {sorted.length === 0 ? (
        <p class="empty-state">Noch keine Modelle dokumentiert. In Arbeit.</p>
      ) : (
        <div class="model-grid">
          {sorted.map((m) => (
            <a href={`/modelle/${m.id.replace(/\.md$/, "")}`} class="model-card">
              <span class="model-type">{m.data.type}</span>
              <h2 class="model-name">{m.data.name}</h2>
              <p class="model-desc">{m.data.description}</p>
              {m.data.vramRequirement && <span class="model-vram">VRAM: {m.data.vramRequirement}</span>}
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</LandingLayout>

<style>
  .overview { padding-block: var(--space-12) var(--space-20); }
  .overview-inner { max-width: 1280px; margin: 0 auto; padding: 0 var(--space-6); }
  .overview-heading { font-size: var(--text-4xl); font-weight: var(--font-weight-bold); color: var(--color-text-primary); margin-block-end: var(--space-4); }
  .overview-lead { font-size: var(--text-lg); color: var(--color-text-secondary); max-width: 56ch; margin-block-end: var(--space-12); }
  .empty-state { color: var(--color-text-tertiary); font-size: var(--text-lg); padding: var(--space-16) 0; text-align: center; }
  .model-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-4); }
  @media (min-width: 640px) { .model-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .model-grid { grid-template-columns: repeat(3, 1fr); } }
  .model-card { display: flex; flex-direction: column; gap: var(--space-2); padding: var(--space-5); background: var(--color-surface-1); border: 1px solid var(--color-surface-3); border-radius: var(--radius-lg); transition: transform 200ms ease; }
  .model-card:hover { transform: translateY(-2px); }
  .model-type { font-size: var(--text-xs); color: var(--color-accent); text-transform: uppercase; font-weight: var(--font-weight-medium); }
  .model-name { font-size: var(--text-lg); font-weight: var(--font-weight-semibold); }
  .model-desc { font-size: var(--text-sm); color: var(--color-text-secondary); }
  .model-vram { font-size: var(--text-xs); color: var(--color-text-tertiary); font-family: var(--font-mono); }
</style>
