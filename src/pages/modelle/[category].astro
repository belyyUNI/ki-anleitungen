---
import LandingLayout from "@layouts/LandingLayout.astro";
import { getCollection } from "astro:content";

const allModels = await getCollection("modelle", ({ data }) => !data.draft);

const categoryLabels: Record<string, string> = {
  "stable-diffusion": "Stable Diffusion",
  flux: "Flux",
  llm: "Large Language Models",
  other: "Weitere Modelle",
};

const categoryDescriptions: Record<string, string> = {
  "stable-diffusion": "Checkpoints, LoRAs, VAEs und ControlNet-Modelle fur Stable Diffusion.",
  flux: "Flux-basierte Bildgenerierungsmodelle.",
  llm: "Large Language Models fur Textgenerierung und Chat.",
  other: "Spezielle und experimentelle KI-Modelle.",
};

export function getStaticPaths() {
  const categories = ["stable-diffusion", "flux", "llm", "other"];
  return categories.map((category) => ({ params: { category } }));
}

const { category } = Astro.params;
const label = categoryLabels[category] ?? category;
const description = categoryDescriptions[category] ?? "";

const typeLabels: Record<string, string> = {
  checkpoint: "Checkpoint",
  lora: "LoRA",
  controlnet: "ControlNet",
  vae: "VAE",
  upscaler: "Upscaler",
  "text-encoder": "Text Encoder",
  llm: "LLM",
  other: "Sonstiges",
};

const entries = allModels
  .filter((m) => m.data.category === category)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
---

<LandingLayout
  title={`${label} - KI-Modelle`}
  description={`${label}: ${description} ${entries.length} Modelle verfugbar.`}
>
  <div class="page">
    <div class="hero">
      <a href="/modelle/" class="back-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Alle Modelle
      </a>
      <h1>{label}</h1>
      <p class="lead">{description}</p>
    </div>

    {
      entries.length > 0 ? (
        <div class="grid">
          {entries.map((m) => (
            <a href={`/modelle/${m.id.replace(/\.md$/, "")}`} class="card">
              <div class="card-header">
                <span class="card-type">{typeLabels[m.data.type] ?? m.data.type}</span>
                {m.data.vramRequirement && <span class="card-vram">{m.data.vramRequirement}</span>}
              </div>
              <h2 class="card-title">{m.data.name}</h2>
              <p class="card-desc">{m.data.description.length > 120 ? m.data.description.slice(0, 120) + "..." : m.data.description}</p>
              <div class="card-footer">
                <span class="card-source">{m.data.source}</span>
                {m.data.fileSize && <span class="card-size">{m.data.fileSize}</span>}
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="empty">
          <p>Noch keine Modelle in dieser Kategorie dokumentiert.</p>
          <a href="/modelle/">Zuruck zur Ubersicht</a>
        </div>
      )
    }
  </div>
</LandingLayout>

<style>
  .page {
    max-width: 1280px;
    margin: 0 auto;
    padding: var(--space-8) var(--space-6) var(--space-24);
  }

  .hero {
    margin-block-end: var(--space-12);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin-block-end: var(--space-4);
    transition: color 150ms ease;
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  h1 {
    font-size: var(--text-3xl);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin-block-end: var(--space-2);
  }

  .lead {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .grid { grid-template-columns: repeat(3, 1fr); }
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-5);
    background-color: var(--color-surface-1);
    border: 1px solid var(--color-surface-3);
    border-radius: var(--radius-lg);
    transition: transform 200ms ease, box-shadow 200ms ease;
  }

  .card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card-hover);
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .card-type {
    font-size: var(--text-xs);
    font-weight: var(--font-weight-medium);
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .card-vram {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    font-family: var(--font-mono);
  }

  .card-title {
    font-size: var(--text-lg);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
  }

  .card-desc {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    flex: 1;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .card-source {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
  }

  .card-size {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    font-family: var(--font-mono);
  }

  .empty {
    text-align: center;
    padding: var(--space-16) var(--space-8);
    color: var(--color-text-secondary);
  }

  .empty a {
    color: var(--color-accent);
    font-weight: var(--font-weight-medium);
  }
</style>
