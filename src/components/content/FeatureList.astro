---
export interface FeatureItem {
  icon: string;
  title: string;
  description: string;
  href: string;
}

const features: FeatureItem[] = [
  {
    icon: "&#9654;_",
    title: "DGX Server & GPU",
    description: "Setup, Konfiguration und Betrieb von DGX-Servern. GPU-Treiber, CUDA, Multi-GPU-Setups und Performance-Tuning.",
    href: "/guides/dgx/",
  },
  {
    icon: "&#9633;",
    title: "Docker & Container",
    description: "GPU-Passthrough, docker-compose Multi-GPU, Image-Building und Container-Orchestrierung fur KI-Workloads.",
    href: "/guides/docker/",
  },
  {
    icon: "&#9670;",
    title: "ComfyUI & Workflows",
    description: "Installation, Custom Nodes, komplexe Workflows, Performance-Optimierung und Fehlerbehebung.",
    href: "/guides/comfyui/",
  },
  {
    icon: "&#9883;",
    title: "KI-Modelle",
    description: "SDXL, Flux, LLaMA und mehr. Download, Konvertierung, VRAM-Anforderungen und Vergleich.",
    href: "/modelle/",
  },
  {
    icon: "&#9881;",
    title: "Troubleshooting",
    description: "CUDA OOM, Treiber-Konflikte, Docker-Permissions, Modell-Ladefehler und andere haufige Probleme.",
    href: "/troubleshooting/",
  },
  {
    icon: "&#9733;",
    title: "Workflows & Automation",
    description: "Bewahrte Workflows fur img2img, ControlNet, Upscaling und mehr. Direkt importierbar in ComfyUI.",
    href: "/workflows/",
  },
];
---

<section class="features" aria-labelledby="features-heading">
  <div class="features-inner">
    <h2 id="features-heading" class="features-heading">
      Alles, was du fur deine KI-Infrastruktur brauchst
    </h2>
    <p class="features-sub">
      Strukturierte Anleitungen und Referenzen fur den gesamten Stack &mdash; vom Server bis zum Modell.
    </p>

    <div class="features-grid">
      {
        features.map((f) => (
          <a href={f.href} class="feature-card">
            <span class="feature-icon" aria-hidden="true">{f.icon}</span>
            <h3 class="feature-title">{f.title}</h3>
            <p class="feature-desc">{f.description}</p>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .features {
    padding-block: var(--space-20);
  }

  .features-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 var(--space-6);
  }

  .features-heading {
    font-size: var(--text-3xl);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
    color: var(--color-text-primary);
    text-align: center;
    margin-block-end: var(--space-4);
  }

  .features-sub {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    text-align: center;
    max-width: 48ch;
    margin: 0 auto var(--space-16);
  }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .feature-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-6);
    background-color: var(--color-surface-1);
    border: 1px solid var(--color-surface-3);
    border-radius: var(--radius-xl);
    transition: transform 200ms ease, border-color 200ms ease, box-shadow 200ms ease;
  }

  .feature-card:hover {
    transform: translateY(-2px);
    border-color: rgba(0, 212, 170, 0.3);
    box-shadow: var(--shadow-card-hover);
  }

  .feature-icon {
    font-family: var(--font-mono);
    font-size: var(--text-xl);
    color: var(--color-accent);
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-accent-muted);
    border-radius: var(--radius-md);
  }

  .feature-title {
    font-size: var(--text-lg);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
  }

  .feature-desc {
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
  }
</style>
