---
export interface Props {
  as?: "div" | "article" | "li";
  href?: string;
  hoverable?: boolean;
  class?: string;
}

const { as: Tag = "div", href, hoverable = href != null, class: className } = Astro.props;

const baseClass = `group block bg-surface-1 border border-surface-3 rounded-xl transition-all duration-200 ${
  hoverable ? "hover:-translate-y-1 hover:shadow-card-hover card-hoverable" : ""
} ${className ?? ""}`;
---

{
  href ? (
    <a href={href} class={baseClass}>
      <slot />
    </a>
  ) : (
    <Tag class={baseClass}>
      <slot />
    </Tag>
  )
}

<style>
  .card-hoverable:hover {
    border-color: color-mix(in srgb, var(--color-accent) 30%, transparent);
  }
</style>
