---
export interface Props {
  variant?: "primary" | "secondary" | "ghost";
  size?: "sm" | "md" | "lg";
  href?: string;
  type?: "button" | "submit";
  class?: string;
}

const {
  variant = "primary",
  size = "md",
  href,
  type = "button",
  class: className,
} = Astro.props;

const baseClass = "inline-flex items-center justify-center gap-2 font-medium no-underline transition-all duration-150 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent rounded-lg select-none";

const variantClasses = {
  primary:
    "bg-accent text-[var(--color-surface-0)] hover:bg-accent-hover shadow-[var(--shadow-button)] hover:shadow-[var(--shadow-glow)] hover:-translate-y-px active:translate-y-0",
  secondary:
    "bg-surface-2 text-text-primary border border-surface-3 hover:border-accent hover:text-accent",
  ghost:
    "text-text-secondary hover:text-text-primary hover:bg-surface-2",
};

const sizeClasses = {
  sm: "text-sm px-3 py-1.5",
  md: "text-sm px-5 py-2.5",
  lg: "text-base px-6 py-3",
};

const classes = `${baseClass} ${variantClasses[variant]} ${sizeClasses[size]} ${className ?? ""}`;
---

{
  href ? (
    <a href={href} class={classes}>
      <slot />
    </a>
  ) : (
    <button type={type} class={classes}>
      <slot />
    </button>
  )
}
