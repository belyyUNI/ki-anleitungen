---
import BaseLayout, { type Props as BaseProps } from "./BaseLayout.astro";
import Header from "@components/shell/Header.astro";
import Footer from "@components/shell/Footer.astro";
import Sidebar from "@components/shell/Sidebar.astro";
import Breadcrumbs from "@components/shell/Breadcrumbs.astro";
import TableOfContents from "@components/interactive/TableOfContents.astro";
import type { Crumb } from "@components/shell/Breadcrumbs.astro";

export interface Props extends BaseProps {
  section: "guides" | "modelle" | "workflows" | "troubleshooting";
  currentPath: string;
  crumbs: Crumb[];
}

const { section, currentPath, crumbs, ...baseProps } = Astro.props;
---

<BaseLayout {...baseProps}>
  <Header />
  <div class="content-wrapper">
    <aside class="content-sidebar">
      <Sidebar section={section} currentPath={currentPath} />
    </aside>
    <main class="content-main" id="main-content" data-pagefind-body>
      <Breadcrumbs crumbs={crumbs} />
      <slot />
    </main>
    <aside class="content-toc" aria-label="Inhaltsverzeichnis">
      <TableOfContents />
    </aside>
  </div>
  <Footer />
</BaseLayout>

<style>
  .content-wrapper {
    max-width: 1280px;
    margin: 0 auto;
    padding: var(--space-8) var(--space-6) var(--space-16);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  @media (min-width: 768px) {
    .content-wrapper {
      grid-template-columns: 220px 1fr;
      gap: var(--space-10);
    }
  }

  @media (min-width: 1024px) {
    .content-wrapper {
      grid-template-columns: 240px 1fr 180px;
    }
  }

  .content-sidebar {
    display: none;
  }

  @media (min-width: 768px) {
    .content-sidebar {
      display: block;
      position: sticky;
      top: 80px;
      align-self: start;
      max-height: calc(100vh - 100px);
      overflow-y: auto;
    }
  }

  .content-main {
    min-width: 0;
    max-width: 72ch;
  }

  @media (min-width: 1024px) {
    .content-main {
      max-width: none;
    }
  }

  .content-toc {
    display: none;
  }

  @media (min-width: 1024px) {
    .content-toc {
      display: block;
      position: sticky;
      top: 80px;
      align-self: start;
      max-height: calc(100vh - 100px);
      overflow-y: auto;
    }
  }
</style>
